# ── Watchlist ──────────────────────────────────────────────────────────────────
STOCK_LIST=AAPL,TSLA,MSFT,NVDA

# ── AI Provider (configure at least one) ──────────────────────────────────────

# OpenAI (or any OpenAI-compatible provider like DeepSeek)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.deepseek.com/v1   # uncomment for non-OpenAI providers

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-pro

# ── Notification Channels ──────────────────────────────────────────────────────

# Email (Gmail example — use an App Password, not your login password)
# EMAIL_SENDER=you@gmail.com
# EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_RECEIVERS=you@gmail.com,other@example.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABCdef...
# TELEGRAM_CHAT_ID=-100123456789

# Discord
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789

# ── News Sources (optional but recommended) ────────────────────────────────────
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=BSA...

# ── Behavior ───────────────────────────────────────────────────────────────────
REPORT_TYPE=full          # full | simple | brief
NEWS_MAX_AGE_DAYS=3
BIAS_THRESHOLD=5.0        # % deviation from MA20 before "no chasing highs" warning
